{
  "name": "@zcohen-nerd/brand",
  "version": "1.0.0",
  "description": "Shared Docusaurus brand system for the zcohen-nerd ecosystem — design tokens, Infima bridge, swizzled Navbar + Footer with docs-sidebar support, and the canonical project registry.",
  "license": "MIT",
  "main": "index.js",
  "files": [
    "index.js",
    "tokens/",
    "src/components/",
    "src/data/",
    "src/infima-bridge.css",
    "assets/"
  ],
  "exports": {
    ".": "./index.js",
    "./tokens/zcohen-nerd-tokens.css": "./tokens/zcohen-nerd-tokens.css",
    "./src/infima-bridge.css": "./src/infima-bridge.css",
    "./src/components/*": "./src/components/*",
    "./src/data/projects": "./src/data/projects.js",
    "./src/data/projects.js": "./src/data/projects.js",
    "./src/data/defaultBrand": "./src/data/defaultBrand.js",
    "./src/data/defaultBrand.js": "./src/data/defaultBrand.js",
    "./assets/*": "./assets/*"
  },
  "scripts": {
    "pack:dry": "npm pack --dry-run"
  },
  "keywords": [
    "docusaurus",
    "docusaurus-theme",
    "brand-system",
    "design-tokens",
    "zcohen-nerd",
    "brand"
  ],
  "peerDependencies": {
    "@docusaurus/core": ">=3.0.0",
    "react": ">=18.0.0",
    "react-dom": ">=18.0.0"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/zcohen-nerd/zcohen-nerd-brand.git"
  }
}
